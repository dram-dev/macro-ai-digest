# Copy to .env and fill in. Never commit .env.

# ── Database ──────────────────────────────────────────────
DB_PATH=./data/state.db

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Reddit (OPTIONAL — default ingestor uses public JSON, no auth) ────────
# As of late 2025, Reddit requires pre-approval for personal-use API scripts.
# Default mode hits the public /top.json endpoint and needs no credentials.
# Only fill these in if your Reddit data API request was approved AND you
# also set REDDIT_USE_PRAW=true below to flip to the PRAW path.
# Create app: https://www.reddit.com/prefs/apps → "script" type
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=macro-ai-digest/0.1 by u/your_username

# Set to "true" only after your Reddit API approval comes through
REDDIT_USE_PRAW=false

# ── FRED (free) ───────────────────────────────────────────
# Get key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ── SEC EDGAR (free, user-agent required) ─────────────────
# SEC requires a real name + email in the user agent
EDGAR_USER_AGENT=Your Name your.email@example.com

# ── Gmail (OAuth, free) ───────────────────────────────────
# 1. Enable Gmail API: https://console.cloud.google.com/
# 2. Create OAuth client ID (Desktop app)
# 3. Download credentials JSON → save as below
# 4. First run will open browser to authorize; token cached after
GMAIL_CREDENTIALS_PATH=./secrets/gmail_credentials.json
GMAIL_TOKEN_PATH=./secrets/gmail_token.json
GMAIL_LABEL=Digest/Economist

# ── Summarizer backend (Phase 2) ──────────────────────────
# Options: mlx_local | claude_cli_pro | haiku_api | gemini_flash_free | local_qwen
# mlx_local      = $0 fully local (Qwen3.6-27B on the MLX server). Default —
#                  won the May 2026 trial vs claude_cli_pro (92% vs 55% success)
# claude_cli_pro = $0 (uses your Pro plan via `claude -p`); fails when Pro
#                  rate limits collide with interactive use
# haiku_api      = ~$0.50–1/mo, requires ANTHROPIC_API_KEY below
# gemini_flash   = $0 free tier, requires GEMINI_API_KEY
# local_qwen     = $0 fully local (Ollama 14B), lower quality prose
SUMMARIZER_BACKEND=mlx_local
SUMMARIZER_MODEL=sonnet
SUMMARIZER_MAX_PER_RUN=20
# Per-source cap within a run — stops one chatty feed from dominating the batch
SUMMARIZER_MAX_PER_SOURCE=15
SUMMARIZER_TIMEOUT_SEC=120
# Keep-items older than this never get summarized (0 disables). Stops capped-out
# sources (RSS) from accumulating an ever-growing backlog.
SUMMARIZER_MAX_AGE_DAYS=30

# Optional API keys (only needed for the matching backend above)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Triage (Ollama, Phase 2) ──────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
TRIAGE_MIN_SCORE=0.5
TRIAGE_LOOKBACK_HOURS=24

# ── Embeddings / clustering ───────────────────────────────
# Vectors come from Ollama (the MLX server does completions only). Pull once:
#   ollama pull nomic-embed-text
# Without the model, clustering falls back to TF-IDF automatically.
EMBED_MODEL=nomic-embed-text
# HDBSCAN: smallest group of items that counts as a narrative cluster.
CLUSTER_MIN_SIZE=4

# ── Full-text extraction ──────────────────────────────────
# Feeds (RSS/Substack) and HN external links often ship only a teaser. When a
# feed body is shorter than FULLTEXT_MIN_CHARS, fetch the source URL and
# extract the main article body (boilerplate removed) so triage + summarize see
# the real content. Set FULLTEXT_ENABLED=false to keep raw feed excerpts.
FULLTEXT_ENABLED=true
FULLTEXT_MIN_CHARS=600
FULLTEXT_MAX_CHARS=8000
FULLTEXT_TIMEOUT_SEC=12

# ── Telegram push notifications ───────────────────────────
# Terse mobile alerts for high-signal items. No-op unless BOTH token + chat id
# are set. Setup: message @BotFather → /newbot → copy the token; then message
# your new bot once and read your chat id from
#   https://api.telegram.org/bot<TOKEN>/getUpdates   (or message @userinfobot)
# Verify with:  uv run digest notify --test
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFY_ENABLED=true
# Triage score a new item must hit to earn a push (0.80 = "Balanced").
NOTIFY_MIN_SCORE=0.80
# Max pushes per pipeline run.
NOTIFY_MAX_PER_RUN=5
# Optional once-per-run "Brief ready" ping with an obsidian:// deep link.
NOTIFY_BRIEF_PING=false

# ── Obsidian vault (Phase 3) ──────────────────────────────
# Absolute path to the vault root, NOT including the digest dir.
OBSIDIAN_VAULT_PATH=/Users/dramsey/Documents/Obsidian Vault/vault_build
OBSIDIAN_DIGEST_DIR=80 Digest
# Max items in Topics/<Topic>.md; older entries roll into frozen per-month
# files under Topics/Archive/ (0 = keep everything in one file).
OBSIDIAN_TOPIC_ARCHIVE_CAP=200

# ── Clipped X-post folder (Phase 3.5) ─────────────────────
# Folder inside the vault where you drop X-post .md files (e.g. via Obsidian
# Web Clipper). Resolved relative to OBSIDIAN_VAULT_PATH unless absolute.
# Anything dropped here bypasses Qwen triage, gets summarized uncapped, and
# appears at the top of the daily note in "## Clipped for investigation".
# After processing, the source .md is left in place but stamped with
# `digest_processed_at` in its frontmatter so re-runs skip it.
OBSIDIAN_CLIP_DIR=77_Claude_Investigate

# ── Databricks medallion sink (shared-catalog lakehouse) ──────────────────
# Best-effort writes to a Databricks lakehouse alongside SQLite (SQLite stays
# source of truth). All writes no-op when DATABRICKS_ENABLED=false. Shared
# catalog `digest`, schemas prefixed per domain — macro_* here, pc_* in
# pc-insurance-digest. Apply sql/databricks/{bronze,silver,gold}.sql.
DATABRICKS_ENABLED=false
DATABRICKS_HOST=
DATABRICKS_HTTP_PATH=
DATABRICKS_TOKEN=
DATABRICKS_CATALOG=digest
DATABRICKS_SCHEMA_PREFIX=macro_
